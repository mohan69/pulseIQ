DATABASE_URL="postgresql://pulseiq:change-me@localhost:5432/pulseiq?schema=public"
PULSEIQ_DATA_MODE=memory
INTERNAL_APP_MODE=true
DEPLOYMENT_PROTECTION_NOTE="Protected by Vercel Authentication"
PULSEIQ_MAX_UPLOAD_BYTES=10485760
PULSEIQ_MAX_EXTRACTED_CHARS=100000
PULSEIQ_XLSX_MAX_ROWS_PER_SHEET=200

# Optional. Not required for deterministic demo or database persistence.
AI_PROVIDER=mock
OPENAI_API_KEY=

# Optional OpenRouter provider. Used only when AI_PROVIDER=openrouter or when
# OPENROUTER_API_KEY is present and AI_PROVIDER is unset.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="openrouter/auto"
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME="PulseIQ"
